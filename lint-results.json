 that masks the global scope using a Proxy or by throwing on access.\n        // We use the Function constructor to isolate the scope, and we inject strictly the requested context.\n        const fnTemplate = `\n            return function(${keys.join(',')}) {\n                \"use strict\";\n                try {\n                    ${code}\n                } catch(e) {\n                    return e;\n                }\n            }\n        `;\n\n        const executor = new Function(fnTemplate)();\n        return executor(...values);\n    } catch (err) {\n        console.error(\"SciFlow Sandbox Error:\", err);\n        return err;\n    }\n}\n","usedDeprecatedRules":[]},{"filePath":"/home/lestad/github/sci-flow/packages/core/src/workers/pathfinding.worker.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/lestad/github/sci-flow/packages/core/src/workers/workerFactory.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]}]
