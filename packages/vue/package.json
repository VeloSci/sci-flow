{
  "name": "@sci-flow/vue",
  "version": "0.1.0",
  "description": "Vue 3 adapter for sci-flow",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@sci-flow/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "unplugin-vue": "^7.1.1",
    "vue-tsc": "^3.2.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
