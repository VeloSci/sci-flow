{
  "name": "@sci-flow/core",
  "version": "1.1.0",
  "description": "Core agnostic engine for sci-flow",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "VeloSci",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VeloSci/sci-flow.git"
  },
  "keywords": [
    "sci-flow",
    "flowchart",
    "node editor",
    "scientific layout",
    "webgl",
    "canvas"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}