{
  "name": "@sci-flow/svelte",
  "version": "1.1.0",
  "type": "module",
  "description": "Svelte adapter for sci-flow",
  "author": "VeloSci",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VeloSci/sci-flow.git"
  },
  "keywords": [
    "sci-flow",
    "flowchart",
    "node editor",
    "svelte"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --format esm,cjs --watch",
    "build": "tsup src/index.ts --format esm,cjs --clean",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "eslint": "^10.0.2",
    "esbuild-svelte": "^0.9.4",
    "svelte": "^5.0.0",
    "svelte-preprocess": "^6.0.3",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@sci-flow/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}