{
  "name": "@sci-flow/react",
  "version": "1.0.1",
  "description": "React adapter for sci-flow",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "VeloSci",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VeloSci/sci-flow.git"
  },
  "keywords": [
    "sci-flow",
    "flowchart",
    "node editor",
    "react",
    "hooks"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@sci-flow/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
